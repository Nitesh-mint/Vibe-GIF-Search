{
  "manifest_version": 2,
  "name": "AI Vibe GIF Search",
  "version": "1.0",
  "permissions": [
    "storage",
    "https://generativelanguage.googleapis.com/*",
    "https://api.giphy.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup_neo_brutalist.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "vibe-gif-search@extension"
    }
  }
}